# Cal.com-Buchungslink für das Erstgespräch.
# Echte URL hier eintragen und Datei als .env speichern → der Cal.com-Embed
# erscheint automatisch. Solange dieser Platzhalter steht, zeigt die Sektion
# stattdessen ein Anfrage-Panel mit E-Mail-CTA (kein kaputter iFrame).
VITE_CAL_URL=https://cal.com/leadsystems/erstgespraech

# Kontaktadresse für das Anfrage-Panel (Fallback, wenn kein Buchungslink gesetzt ist).
VITE_CONTACT_EMAIL=kontakt@leadsystems.de
